local alreadyExecuted = false

local function loadScript(urlOrCode)
    if not urlOrCode then return end
    
    local success, err = pcall(function()
        if urlOrCode:find("http") then
            -- It's a URL → load with HttpGet
            local code = HttpService:GetAsync(urlOrCode)
            loadstring(code)()
        else
            -- It's raw code
            loadstring(urlOrCode)()
        end
    end)
    
    if success then
        print("✅ Successfully loaded script for PlaceId: " .. currentPlaceId)
    else
        warn("❌ Failed to load script: " .. tostring(err))
    end
end

